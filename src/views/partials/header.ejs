<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Todos</title>
  <!-- Bootstrap 5 CSS — loads from CDN, no download needed -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    body { background-color: #f8f9fa; }
    .sidebar { min-height: 100vh; background: #212529; }
    .sidebar .nav-link { color: #adb5bd; border-radius: 8px; }
    .sidebar .nav-link:hover { background: #343a40; color: #fff; }
    .sidebar .nav-link.active { background: #0d6efd; color: #fff; }
    .todo-card { transition: box-shadow 0.15s; }
    .todo-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
    .todo-card.done .todo-title { text-decoration: line-through; color: #adb5bd; }
    .check-btn { width: 22px; height: 22px; padding: 0; border-radius: 5px; }
  </style>
</head>
